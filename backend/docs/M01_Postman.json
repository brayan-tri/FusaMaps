{
  "info": {
    "name": "FusaMaps M01 – Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://172.18.4.168:3000/api" },
    { "key": "access_token",  "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "✅ Health Check",
      "request": { "method": "GET", "url": "http://172.18.4.168:3000/health" }
    },
    {
      "name": "1. Registro",
      "event": [{ "listen": "test", "script": { "exec": [
        "const r = pm.response.json();",
        "if(r.success){ pm.collectionVariables.set('access_token', r.data.accessToken); pm.collectionVariables.set('refresh_token', r.data.refreshToken); }"
      ]}}],
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/register",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"email\": \"juan@fusamaps.co\",\n  \"password\": \"Fusa2024!\",\n  \"telefono\": \"3101234567\"\n}" }
      }
    },
    {
      "name": "2. Login",
      "event": [{ "listen": "test", "script": { "exec": [
        "const r = pm.response.json();",
        "if(r.success){ pm.collectionVariables.set('access_token', r.data.accessToken); pm.collectionVariables.set('refresh_token', r.data.refreshToken); }"
      ]}}],
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan@fusamaps.co\",\n  \"password\": \"Fusa2024!\"\n}" }
      }
    },
    {
      "name": "3. Mi perfil",
      "request": {
        "method": "GET", "url": "{{base_url}}/auth/me",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
      }
    },
    {
      "name": "4. Actualizar perfil",
      "request": {
        "method": "PUT", "url": "{{base_url}}/auth/me",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Juan Actualizado\",\n  \"telefono\": \"3209876543\"\n}" }
      }
    },
    {
      "name": "5. Recuperar contraseña",
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/forgot-password",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan@fusamaps.co\"\n}" }
      }
    },
    {
      "name": "6. Refresh token",
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/refresh",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}" }
      }
    },
    {
      "name": "7. Logout",
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/logout",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
      }
    },
    {
      "name": "❌ Login incorrecto",
      "request": {
        "method": "POST", "url": "{{base_url}}/auth/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan@fusamaps.co\",\n  \"password\": \"incorrecta\"\n}" }
      }
    }
  ]
}
